# ============================================================================
# DJANGO CONFIGURATION - ARECOM PROJECT
# ============================================================================
# Copy this file to .env and fill in the values for your environment

# ============================================================================
# DEVELOPMENT vs PRODUCTION
# ============================================================================
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-in-production

# ============================================================================
# DATABASE CONFIGURATION - PostgreSQL (Render)
# ============================================================================
# For Render: Get this from your Render PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:pass123@dpg-xxxxx.render.com:5432/arecom_db
DATABASE_URL=postgresql://username:password@localhost:5432/arecom_db

# ============================================================================
# ALLOWED HOSTS - for production deployment
# ============================================================================
# Comma-separated list of allowed domains
# Example: arecom.onrender.com,www.arecom.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# EMAIL CONFIGURATION (for password reset, notifications)
# ============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================================================================
# SUPERUSER CREDENTIALS (created during deployment)
# ============================================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=strong-password-here
DJANGO_SUPERUSER_EMAIL=admin@arecom.com
